VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_FRONTEND_URL=http://localhost:5173
VITE_MEETING_OS_URL=https://your-meeting-os-url.com
# OR for self-hosted within the same domain:
# VITE_MEETING_OS_URL=/apps/meeting-os/dist/index.html

# Web Push Notifications (generate with: npx web-push generate-vapid-keys)
VITE_VAPID_PUBLIC_KEY=your_vapid_public_key_here

# OAuth Integration Providers
# Get these from the respective provider's developer console
VITE_GOOGLE_CLIENT_ID=your_google_oauth_client_id
VITE_MICROSOFT_CLIENT_ID=your_microsoft_oauth_client_id
VITE_SLACK_CLIENT_ID=your_slack_oauth_client_id

# Flock CRM is DB-backed (Supabase) — no env config needed; access is role-based.
